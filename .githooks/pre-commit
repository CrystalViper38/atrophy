#!/bin/sh
# atrophy pre-commit: secret-scan + the repo's existing anti-leak check.
# Enabled via core.hooksPath .githooks. Both must pass.
set -u

staged=$(git diff --cached --name-only --diff-filter=AM)
if [ -n "$staged" ]; then
  re="BEGIN [A-Z ]*PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{40,}|xox[baprs]-[A-Za-z0-9-]{10,}|sk-[A-Za-z0-9]{20,}|sk-ant-[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{35}"
  fail=0
  for f in $staged; do
    case "$f" in *.lock|*.min.js|*.map|*.png|*.jpg|*.pdf) continue;; esac
    if git show ":$f" 2>/dev/null | grep -nEq "$re"; then
      echo "\033[31m✗ secret probable: $f\033[0m"
      git show ":$f" | grep -nE "$re" | head -3 | sed -E "s/([A-Za-z0-9_-]{6})[A-Za-z0-9_-]{8,}/\1…MASKED/g"
      fail=1
    fi
  done
  if [ "$fail" -ne 0 ]; then
    cat >&2 <<'GUIDE'
[31mCommit bloqué — une clé est écrite en dur dans le code.[0m
[1mOù la mettre (3 étapes) :[0m
  1. Crée/édite un fichier  .env  à la racine de ce projet :   MA_CLE=ta-valeur
  2. Le code lit la valeur, pas le littéral :  Python os.environ["MA_CLE"] (+ load_dotenv) · Node process.env.MA_CLE
  3. Vérifie que .gitignore contient une ligne  .env  → la clé ne partira jamais sur GitHub.
Faux positif (placeholder, doc) ?  git commit --no-verify
GUIDE
    exit 1
  fi
fi

# Existing anti-leak (data files + absolute home paths) — privacy is the product.
exec "$(git rev-parse --show-toplevel)/bin/check-no-leak.sh"
